PORT=5001
# macOS AirPlay uses port 5000 — use 5001 unless you disable AirPlay Receiver in System Settings.
# Database name goes in the path: ...mongodb.net/showtracker?...
# Without it, MongoDB defaults to the "test" database.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/showtracker?retryWrites=true&w=majority
JWT_SECRET=your_production_secure_jwt_secret_key
TMDB_API_KEY=your_tmdb_api_key

# If your MongoDB password contains special characters (@, #, :, /, etc.),
# URL-encode them. Example: India@2021 becomes India%402021
